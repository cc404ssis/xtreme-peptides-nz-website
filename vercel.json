{
  "functions": {
    "api/*.js": { "maxDuration": 10 }
  },
  "outputDirectory": "website",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
